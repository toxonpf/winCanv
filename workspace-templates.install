post_install() {
  cat <<'EOF'
Workspace Templates was installed.

Optional setup:
  1. Start the app once with: workspace-templates
  2. Enable "Workspace Templates Shortcut" in:
     System Settings -> Window Management -> KWin Scripts
  3. If you want autostart, copy:
     /usr/share/applications/io.github.toxonpf.workspacetemplates.desktop
     to ~/.config/autostart/
EOF
}

post_upgrade() {
  post_install
}
